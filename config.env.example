# ===== 必須: AWS認証 =====

# AWSプロファイル名（setup_windows.bat で設定済み）
AWS_PROFILE=chatwork-webhook

# ===== 必須: グローバル接続情報 =====

# SQS キューURL
SQS_QUEUE_URL=https://sqs.ap-northeast-1.amazonaws.com/XXXXXXXXXXXX/chatwork-webhook-queue

# ===== デバッグ通知（ChatWorkルームにエラー・警告を通知）=====
# 1=有効（デフォルト）, 0=無効（ログのみ）
DEBUG_NOTICE_ENABLED=1
# デバッグ通知用ChatWorkアカウントのAPIトークン
DEBUG_NOTICE_CHATWORK_TOKEN=YOUR_DEBUG_NOTICE_TOKEN
# デバッグ通知先のChatWorkルームID（コマンド /status /sysinfo 等もこのルームで受付）
DEBUG_NOTICE_CHATWORK_ROOM_ID=YOUR_ROOM_ID(xxxxxxxxx)

# ===== オプション: AI呼び出し方式 =====
# 1=Anthropic API直接呼び出し（高速）, 0=Claude Code CLI（デフォルト）
USE_DIRECT_API=0

# Anthropic API キー（USE_DIRECT_API=1 の場合に必須）
# https://console.anthropic.com/ で発行
ANTHROPIC_API_KEY=YOUR_ANTHROPIC_API_KEY

# ===== オプション: Claude モデル =====
# claude-haiku-4-5  : 最速・低コスト（デフォルト）
# claude-sonnet-4-6 : バランス型
# claude-opus-4-6   : 最高性能・高コスト
CLAUDE_MODEL=claude-haiku-4-5

# ===== オプション: Claude Code パス（USE_DIRECT_API=0 の場合のみ使用） =====
# CLAUDE_COMMAND=C:\Users\ユーザー名\.claude\local\claude.exe

# ===== オプション: 動作パラメータ =====
# SQSポーリング方式: 0=ショートポーリング（デフォルト）, 1-20=ロングポーリング（秒）
# ロングポーリングはSQSコスト削減に有効。通常は20を推奨。
# ロングポーリング時は POLL_INTERVAL は無効（Waitが代わりのインターバルになる）
SQS_WAIT_TIME_SECONDS=1
POLL_INTERVAL=0.5
CLAUDE_TIMEOUT=60
FOLLOWUP_WAIT_SECONDS=30
MAX_AI_CONVERSATION_TURNS=10
REPLY_COOLDOWN_SECONDS=15

# ===== オプション: Google Workspace API =====
# OAuth 認証情報（Google Cloud Console → 認証情報 → OAuthクライアントID で取得）
# Google Drive API / Google Sheets API を有効化しておくこと
# GOOGLE_EMAIL=your-email@example.com
# GOOGLE_OAUTH_CLIENT_ID=xxxxxxxxxxxx.apps.googleusercontent.com
# GOOGLE_OAUTH_CLIENT_SECRET=GOCSPX-xxxxxxxxxxxxxxxx
# マイドライブを参照対象にするか（0=しない（デフォルト）, 1=する）
# GOOGLE_DRIVE_INCLUDE_MY_DRIVE=0
# 共有ドライブを参照対象にするか（0=しない, 1=する（デフォルト））
# GOOGLE_DRIVE_INCLUDE_SHARED=1

# ===== メンバー固有設定は各メンバーフォルダの member.env に記載 =====
# 例: members/01_yamada/member.env
# 詳細は members/templates/member.env.example を参照

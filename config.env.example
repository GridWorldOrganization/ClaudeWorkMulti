AWS_ACCESS_KEY_ID=YOUR_AWS_ACCESS_KEY_ID
AWS_SECRET_ACCESS_KEY=YOUR_AWS_SECRET_ACCESS_KEY

# Chatwork Webhook トークン（Lambda署名検証用）
CW_WEBHOOK_TOKEN_YOKOTA=YOUR_WEBHOOK_TOKEN_YOKOTA
CW_WEBHOOK_TOKEN_FUJINO=YOUR_WEBHOOK_TOKEN_FUJINO

# フォローアップ待機秒数（「確認します」系の返信後、情報収集して再返信するまでの待機時間）
FOLLOWUP_WAIT_SECONDS=30

# AI同士の会話上限ターン数（人間が起点の会話チェーン内で、AIメンバー同士が交わせる最大メッセージ数）
MAX_AI_CONVERSATION_TURNS=10

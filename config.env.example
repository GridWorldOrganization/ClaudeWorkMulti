# ===== 必須: 接続情報（機密） =====

# SQS キューURL
SQS_QUEUE_URL=https://sqs.ap-northeast-1.amazonaws.com/XXXXXXXXXXXX/chatwork-webhook-queue

# Chatwork APIトークン
CW_TOKEN_GURIKO=YOUR_GURIKO_TOKEN
CW_TOKEN_YOKOTA=YOUR_YOKOTA_TOKEN
CW_TOKEN_FUJINO=YOUR_FUJINO_TOKEN

# エラー報告先ルームID
CW_ERROR_ROOM_ID=428354226

# ===== オプション: 動作パラメータ =====

# Claude Code 実行タイムアウト秒数
CLAUDE_TIMEOUT=60

# フォローアップ待機秒数（「確認します」系の返信後、情報収集して再返信するまでの待機時間）
FOLLOWUP_WAIT_SECONDS=30

# AI同士の会話上限ターン数（人間が起点の会話チェーン内で、AIメンバー同士が交わせる最大メッセージ数）
MAX_AI_CONVERSATION_TURNS=10

# 同一メンバーの連投防止クールダウン秒数（前回発言からこの秒数は次の発言を待機する）
REPLY_COOLDOWN_SECONDS=15
